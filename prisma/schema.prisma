generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  // ОБРАТНАЯ СВЯЗЬ: один пользователь → много бронирований
  bookings Booking[]
}

model Booking {
  id String @id @default(uuid())

  // Кто бронирует
  userId String
  user   User   @relation(fields: [userId], references: [id])

  // Объект бронирования (пока абстрактный)
  resource String // например: "room-1", "sauna", "house-2"

  // Временной интервал
  startDate DateTime
  endDate   DateTime

  // Статус бронирования
  status BookingStatus @default(PENDING)

  createdAt DateTime @default(now())
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}
